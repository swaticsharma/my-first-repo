{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@medwise/types": ["packages/types/src/index.ts"],
      "@medwise/types/*": ["packages/types/src/*"],
      "@medwise/db": ["packages/db/src/index.ts"],
      "@medwise/db/*": ["packages/db/src/*"],
      "@medwise/ui": ["packages/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".expo"]
}
